{
  "expo": {
    "name": "Mapa Farma",
    "slug": "mapa-farma",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "mapafarma",
    "userInterfaceStyle": "light",
    "primaryColor": "#7a2833",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mapafarma.app"
    },
    "android": {
      "package": "com.mapafarma.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7a2833"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@maplibre/maplibre-react-native",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "O Mapa Farma usa sua localização para centralizar o mapa e ajudar a traçar rotas até as farmácias."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#7a2833"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ee2a91c4-65ee-412d-a236-0592308cbdff"
      }
    }
  }
}
