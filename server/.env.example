# Conexão Turso / libSQL
# Local (arquivo): TURSO_URL=file:./mapa_farma.db
# Turso remoto:    TURSO_URL=libsql://<seu-banco>.turso.io
TURSO_URL=file:./mapa_farma.db
TURSO_AUTH_TOKEN=

# Autenticação
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=30d

# Servidor
PORT=3001

# Seed Overpass (área de Maceió). Deixe o padrão para importar a cidade toda.
OVERPASS_URL=https://overpass-api.de/api/interpreter
